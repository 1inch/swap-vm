PRIVATE_KEY=0xPRIVATE_KEY
SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com

# Deployed contracts (Sepolia)
AQUA=0x9d143135f084ad33ab2d3662e7dd2dd22f1986a1
ROUTER=0xb9ae8d906a8b61a99c95f55750cbea8e97eb28ba

# ── init-liquidity (InitializeXYCConcentrated) ────────────────────────────────
# Tokens (Sepolia: WETH 18-dec, USDC 6-dec)
TOKEN_A=0xfFf9976782d46CC05630D1f6eBAb18b2324d6B14
TOKEN_B=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
# Amounts (raw): ~0.00465 WETH ≈ 10 USDC at $2150
AMOUNT_A=4651162790697674
AMOUNT_B=10000000
# Prices in 1e18 fp (P = tokenGt/tokenLt in raw amounts)
# P = 1e30 / ETH_USD_PRICE; range ±20% on ETH price ($2150)
PRICE_SPOT=465116279069767441860465116
PRICE_MIN=387596899224806201550387596
PRICE_MAX=581395348837209302325581395
# Fee in 1e9 basis (3000000 = 0.3%)
FEE_BPS=3000000

# ── init-liquidity-from-balances (InitializeXYCConcentratedFromBalances) ──────
# Set exactly one of PRICE_MIN or PRICE_MAX above; the other is derived.
# BALANCE_LT=10000000
# BALANCE_GT=4651162790697674

# Protocol fee (1e9 basis: 2000000 = 0.2%); recipient = 1inch DAO Treasury
PROTOCOL_FEE_BPS=2000000
PROTOCOL_FEE_RECIPIENT=0x7951c7ef839e26F63DA87a42C9a87986507f1c07

# KYC NFT gate (0x0 = off)
KYC_NFT=0x0000000000000000000000000000000000000000

# RPC URL for localhost network
LOCALHOST_RPC_URL=http://localhost:8546
# Replace with your own private key for localhost testing
LOCALHOST_PRIVATE_KEY=0x
